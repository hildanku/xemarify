DB_HOST=localhost
DB_PORT=5445
DB_USERNAME=xemarify_manager
DB_PASSWORD=xemarify_manager
DB_DATABASE=xemarify_manager
DB_SCHEMA=public
DB_SSLMODE=disable
DB_MAX_CONNS=10
DB_MIN_CONNS=1

SERVER_HOST=0.0.0.0
PORT=8089

# Logging level: debug | info | warn | error
LOG_LEVEL=info

# JWT — access token secret (use a long random string in production)
JWT_SECRET=change-me-to-a-long-random-secret
# Access token lifetime  (e.g. 15m, 1h)
JWT_ACCESS_TTL=15m
# Refresh token lifetime (e.g. 168h = 7 days, 720h = 30 days)
JWT_REFRESH_TTL=168h

# Manager setup token (For initial setup only) (use a long random string in production)
MANAGER_SETUP_TOKEN=change-me

# Event ingestion worker pool
# WorkerCount: number of goroutines processing events (fallback: 8)
EVENT_WORKER_COUNT=4
# ChanBuffer: buffered channel size for async processing (fallback: 4096)
EVENT_CHAN_BUFFER=1024